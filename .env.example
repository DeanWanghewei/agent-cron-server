# Database (sqlite for dev, postgresql for prod)
ACS_DATABASE_URL=sqlite+aiosqlite:///./data/cron.db

# Server
ACS_HOST=0.0.0.0
ACS_PORT=8900
ACS_DEBUG=false
ACS_LOG_LEVEL=INFO

# Scheduler
ACS_SCHEDULER_TIMEZONE=Asia/Shanghai

# Runner
ACS_DEFAULT_TASK_TIMEOUT=3600
ACS_LOG_MAX_SIZE=10485760

# Log storage
ACS_LOG_DIR=data/logs
ACS_LOG_RETENTION_DAYS=30

# MCP
ACS_MCP_MOUNT_PATH=/mcp
